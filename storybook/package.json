{
  "name": "prism-storybook",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "storybook:default":  "npm run storybook --workspace=packages/ds-default",
    "build:default":      "npm run build-storybook --workspace=packages/ds-default",
    "storybook:airpals":  "npm run storybook --workspace=packages/airpals-ds",
    "build:airpals":      "npm run build-storybook --workspace=packages/airpals-ds",
    "install:all":        "npm install"
  }
}
